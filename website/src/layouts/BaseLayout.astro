---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Flowmux | Manage Multiple AI Coding Agents in the Terminal',
  description = 'Run Claude Code, Codex, and OpenCode side by side. Flowmux adds a keyboard-first dashboard, Git worktrees, and tmux-backed persistence.',
} = Astro.props;

const site = Astro.site ?? new URL('https://flowmux.dev');
const canonicalUrl = new URL(Astro.url.pathname, site);
const socialImage = new URL('/assets/social/flowmux-social-card.png', site);
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      name: 'Flowmux',
      url: site.href,
      description,
      inLanguage: 'en',
    },
    {
      '@type': 'SoftwareApplication',
      name: 'Flowmux',
      applicationCategory: 'DeveloperApplication',
      operatingSystem: 'Linux, macOS',
      description,
      url: site.href,
      downloadUrl: 'https://github.com/grouzen/flowmux/releases',
      sameAs: ['https://github.com/grouzen/flowmux'],
      isAccessibleForFree: true,
      image: socialImage.href,
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="theme-color" content="#f6f3ec" />
    <link rel="canonical" href={canonicalUrl.href} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Flowmux" />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImage.href} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Flowmux social preview card with the Flowmux logo and the slogan Where agent chaos becomes flow." />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage.href} />
    <meta name="twitter:image:alt" content="Flowmux social preview card with the Flowmux logo and the slogan Where agent chaos becomes flow." />
    <link rel="icon" type="image/png" href="/assets/brand/flowmux-mark.png" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <script is:inline>
      const storedTheme = localStorage.getItem('flowmux-theme');
      const systemTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      const theme = storedTheme || systemTheme;

      document.documentElement.dataset.theme = theme;
      document.documentElement.style.colorScheme = theme;
      document.querySelector('meta[name="theme-color"]')?.setAttribute('content', theme === 'dark' ? '#10100e' : '#f6f3ec');
    </script>
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script>
      const themeButtons = document.querySelectorAll<HTMLButtonElement>('[data-theme-toggle]');
      const media = window.matchMedia('(prefers-color-scheme: dark)');

      function preferredTheme() {
        return localStorage.getItem('flowmux-theme') || (media.matches ? 'dark' : 'light');
      }

      function applyTheme(theme: string) {
        document.documentElement.dataset.theme = theme;
        document.documentElement.style.colorScheme = theme;
        document.querySelector('meta[name="theme-color"]')?.setAttribute('content', theme === 'dark' ? '#10100e' : '#f6f3ec');

        for (const button of themeButtons) {
          button.setAttribute('aria-pressed', String(theme === 'dark'));
          button.setAttribute('aria-label', theme === 'dark' ? 'Switch to light theme' : 'Switch to dark theme');
        }
      }

      for (const button of themeButtons) {
        button.addEventListener('click', () => {
          const nextTheme = preferredTheme() === 'dark' ? 'light' : 'dark';
          localStorage.setItem('flowmux-theme', nextTheme);
          applyTheme(nextTheme);
        });
      }

      media.addEventListener('change', () => {
        if (!localStorage.getItem('flowmux-theme')) {
          applyTheme(preferredTheme());
        }
      });

      applyTheme(preferredTheme());
    </script>
  </body>
</html>
